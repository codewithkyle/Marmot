%!PSL 0.1

page 300 460

fonts begin
  kablammo "fonts/Kablammo.ttf"
end

assets begin
  walmart image "assets/walmart.png"
  fd image "assets/familydollar.webp"
  sn image "assets/SpartanNash.png"
end

draw begin
  1 1 1 rgb
  0 0 300 460 rect fill

  1 0 0 rgb
  20 40 260 40 rect fill

  0 0 0 rgb
  14 fontsize
  center align
  middle valign
  word wrap
  grow textfit
  (kablammo) font
  (Hello Marmot) 20 40 260 40 textbox

  0 1 0 rgb
  20 200 180 60 rect fill
  (walmart) 20 200 180 60 image

  0 0 1 rgb
  100 120 80 85 rect fill
  stretch imagefit
  (fd) 100 120 80 85 image

  0 0 1 rgb
  0 330 160 60 rect fill
  cover imagefit
  (sn) 20 300 160 60 image
end

%!PSL 0.1

page 432 288

slots begin
  sku string required
  product_name string required
  sale_price decimal required
  regular_price decimal required
  buy_qty int required
  get_qty int required
  promo_url string required
end

fonts begin
  kablammo "fonts/Kablammo.ttf"
end

assets begin
  logo_default image "assets/sprout-basket.png"
  logo_alt image "assets/sprout-basket-alt.png"
  save_5 image "assets/save-5.png"
  super_save image "assets/super-save.png"
end

frames begin
  1 FRAME_BASE
  2 FRAME_PRICE_TEXT
  3 FRAME_PRICE_SALE
  4 FRAME_HEADER
  5 FRAME_LOGO_DEFAULT
  6 FRAME_BADGE_DEFAULT
  7 FRAME_BAR_CODES
  8 FRAME_QR_CODES
  9 FRAME_LOGO_SUPER
  10 FRAME_BADGE_SUPER
end

layers begin
  layer 1 LAYER_DEFAULT_THEME begin
    5 FRAME_LOGO_DEFAULT
    6 FRAME_BADGE_DEFAULT
  end

  layer 2 LAYER_SUPER_THEME begin
    9 FRAME_LOGO_SUPER
    10 FRAME_BADGE_SUPER
  end
end

draw begin
  frame 1 begin
    % Card background + border (scripted colors)
    0 0 432 288 rect fill
    8 8 416 272 rect stroke
  end

  frame 2 begin
    % Offer text + regular price (scripted text color)
    (kablammo) font
    32 fontsize
    left align
    middle valign
    (BUY ) $(buy_qty) ( GET ) $(get_qty) 4 concat 26 88 250 44 textbox

    (sans) font
    14 fontsize
    left align
    top valign
    fit textfit
    (Reg $) $(regular_price) 2 concat 30 215 180 10 textbox
  end

  frame 3 begin
    % Sale price (scripted text color)
    (kablammo) font
    58 fontsize
    left align
    top valign
    fit textfit
    ($) $(sale_price) 2 concat 26 136 220 74 textbox
  end

  layer 1 begin
    frame 5 begin
      % Base-theme fallback logo when promo_url is empty
      contain imagefit
      (logo_default) 355 215 60 60 image
    end

    frame 6 begin
      % Base-theme badge
      contain imagefit
      (save_5) 285 90 110 110 image
    end
  end

  layer 2 begin
    frame 9 begin
      % Super-theme fallback logo when promo_url is empty
      contain imagefit
      (logo_alt) 355 215 60 60 image
    end

    frame 10 begin
      % Super-theme badge
      contain imagefit
      (super_save) 285 90 110 110 image
    end
  end

  frame 4 begin
    % Header band
    0.92 0.07 0.16 rgb
    20 18 392 54 rect fill

    (kablammo) font
    22 fontsize
    center align
    middle valign
    1 1 1 rgb
    $(product_name) titlecase 28 24 376 40 textbox
  end

  frame 7 begin
    % Machine-readable codes
    0 0 0 rgb
    $(sku) c128b 26 240 214 28 barcode
  end

  frame 8 begin
    $(promo_url) qr 355 215 60 60 barcode
  end
end
